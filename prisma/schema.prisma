generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Administrator {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  email     String    @unique
  name      String?
  password  String?
  image     String?
  active    Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  roleId    String?    @db.ObjectId
  role      AdminRole? @relation(fields: [roleId], references: [id])
  logAdmins LogAdmin[]
}

model AdminRole {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  administrators Administrator[]
  permissions    AdminRolePermission[]
}

model AdminPermission {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  resource    String
  action      String
  description String?

  roles AdminRolePermission[]

  @@unique([resource, action])
}

model AdminRolePermission {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  adminRoleId       String   @db.ObjectId
  adminPermissionId String   @db.ObjectId
  createdAt         DateTime @default(now())

  role       AdminRole       @relation(fields: [adminRoleId], references: [id], onDelete: Cascade)
  permission AdminPermission @relation(fields: [adminPermissionId], references: [id], onDelete: Cascade)

  @@unique([adminRoleId, adminPermissionId])
}

model LogAdmin {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  administratorId String        @db.ObjectId
  administrator   Administrator @relation(fields: [administratorId], references: [id], onDelete: Cascade)

  action       String
  resource     String?
  resourceId   String?
  resourceName String?

  url String?

  createdAt DateTime @default(now())
}

model Patient {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  name                    String
  cpf                     String?
  birthDate               DateTime
  phone                   String    @unique
  email                   String?
  profession              String?
  gender                  String?
  howKnewClinic           String?
  zipCode                 String?
  state                   String?
  city                    String?
  neighborhood            String?
  street                  String?
  number                  String?
  complement              String?
  observations            String?
  emergencyName           String?
  emergencyPhone          String?
  representativeName      String?
  representativeCpf       String?
  representativeBirthDate DateTime?
  active                  Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  history       PatientHistory[]
  anamneses     Anamnese[]
  odontogram    Odontogram?
  appointments  Appointment[]
  protheticWork ProtheticWork[]
  tasks         PatientTask[]
}

model PatientHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  patientId   String   @db.ObjectId
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PatientTask {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  patientId   String    @db.ObjectId
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Anamnese {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  patientId String  @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  observations String?

  doctorRecommendations String?

  panicOrBehaviorNotes String?

  requiresMedicalClearance Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  diseases    AnamneseDisease[]
  allergies   AnamneseAllergy[]
  medications ContinuousMedication[]
}

model AnamneseDisease {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  anamneseId String   @db.ObjectId
  anamnese   Anamnese @relation(fields: [anamneseId], references: [id], onDelete: Cascade)

  name String

  observations String?
}

model AnamneseAllergy {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  anamneseId String   @db.ObjectId
  anamnese   Anamnese @relation(fields: [anamneseId], references: [id], onDelete: Cascade)

  substance String

  reaction String?
}

model ContinuousMedication {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  anamneseId String   @db.ObjectId
  anamnese   Anamnese @relation(fields: [anamneseId], references: [id], onDelete: Cascade)

  medication String

  dosage String?

  frequency String?

  medicalFollowUp String?
}

model Odontogram {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  patientId String  @unique @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teeth Tooth[]
}

model Tooth {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  odontogramId String     @db.ObjectId
  odontogram   Odontogram @relation(fields: [odontogramId], references: [id], onDelete: Cascade)

  toothKey   String
  isCustom   Boolean     @default(false)
  customName String?
  status     ToothStatus
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([odontogramId, toothKey])
}

enum ToothStatus {
  HEALTHY     @map("SAUDAVEL")
  CAVITY      @map("CARIE")
  ENDODONTICS @map("ENDODONTIA")
  PROSTHESIS  @map("PROTESE")
  IMPLANT     @map("IMPLANTE")
  EXTRACTED   @map("EXTRAIDO")
  RETAINED    @map("RETIDO")
  OTHER       @map("OUTRO")
}

model Appointment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  patientId  String?  @db.ObjectId
  patient    Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
  guestName  String?
  guestPhone String?

  scheduledAt    DateTime
  serviceType    String
  estimatedValue Float
  description    String?
  status         AppointmentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledAt])
  @@index([status, scheduledAt])
}

enum AppointmentStatus {
  PENDING   @map("PENDENTE")
  CONFIRMED @map("CONFIRMADO")
  CANCELLED @map("CANCELADO")
  COMPLETED @map("REALIZADO")
}

enum WorkStatus {
  PENDING @map("PENDENTE")
  DONE    @map("CONCLUIDO")
}

model ProtheticWork {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  patientId     String?    @map("paciente_id") @db.ObjectId
  patient       Patient?   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientName   String     @map("nome_paciente")
  patientCpf    String?    @map("cpf_paciente")
  laboratory    String     @map("laboratorio")
  workName      String     @map("nome_trabalho")
  description   String     @map("descricao")
  status        WorkStatus @default(PENDING)
  sentAt        DateTime   @map("data_envio")
  teethInvolved String?    @map("dentes_envolvidos")
  value         Float?     @map("valor")
  notes         String?    @map("observacoes")
  createdBy     String     @map("created_by") @db.ObjectId
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("trabalhos_proteticos")
}

model Product {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String    @map("nome")
  quantity        Int       @default(0) @map("quantidade")
  minimumQuantity Int       @default(0) @map("quantidade_minima")
  expirationDate  DateTime? @map("data_validade")
  notes           String?   @map("observacoes")
  createdBy       String    @map("created_by") @db.ObjectId
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  movements StockMovement[]

  @@map("produtos")
}

model StockMovement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @map("produto_id") @db.ObjectId
  productName String   @map("nome_produto")
  quantity    Int?     @map("quantidade")
  type        String   @map("tipo")
  notes       String?  @map("observacoes")
  performedBy String   @map("realizado_por")
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("movimentacoes_estoque")
}

model GeneratedLink {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  patientName  String
  hasAnamnesis Boolean
  formType     String
  token        String    @unique
  used         Boolean   @default(false)
  usedAt       DateTime?
  expiresAt    DateTime  @default(now()) @map("expires_at")
  link         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
